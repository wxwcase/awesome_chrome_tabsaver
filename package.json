{
  "name": "@amzn/awesome-chrome-tab-saver",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "repository": "ssh://git.amazon.com/pkg/AwesomeChromeTabSaver",
  "homepage": "https://code.amazon.com/packages/AwesomeChromeTabSaver",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "clean": "rm -rf dist && rm -rf node_modules",
    "build": "tsc",
    "watch": "tsc -w",
    "prepublishOnly": "npm run build && npm run test",
    "test": "vitest run --coverage",
    "posttest": "generate-coverage-data --language typescript"
  },
  "main": "./dist/math.js",
  "exports": "./dist/math.js",
  "files": [
    "dist/",
    "!/dist/**/__tests__/*"
  ],
  "npm-pretty-much": {
    "runTest": "never"
  },
  "devDependencies": {
    "@amzn/brazil": "^2.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.2"
  }
}
